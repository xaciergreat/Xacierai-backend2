{
  "builds": [
    {
      "src": "artifacts/api-server/package.json",
      "use": "@vercel/node",
      "config": {
        "nodeVersion": "18.x"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "artifacts/api-server/dist/index.mjs"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
