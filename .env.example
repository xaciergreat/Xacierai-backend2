
# OpenAI API Configuration
# NOTE: API keys are now hardcoded in the application code
# OPENAI_API_KEY=sk-your-key-here

# Groq API Configuration
# NOTE: API keys are now hardcoded in the application code
# GROQ_API_KEY=your-groq-key-here

# Node Environment
NODE_ENV=production

# Server Configuration
PORT=3000
HOST=0.0.0.0

# CORS Configuration - Allow Vercel Frontend
CORS_ORIGIN=https://xacierai-frontend.vercel.app

# Logging
LOG_LEVEL=info
